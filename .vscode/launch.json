{
  "version": "0.2.0",
  "configurations": [
    // -------------------------------------------------------------------------
    // Backend en Docker — adjunta al proceso Node.js (tsx --inspect)
    // Requisito: docker compose up -d  (puerto 9229 expuesto)
    // El inspector estará listo ~5s después de que el contenedor arranque.
    // -------------------------------------------------------------------------
    {
      "name": "Backend: Attach (Docker)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "127.0.0.1",
      "localRoot": "${workspaceFolder}/backend",
      "remoteRoot": "/app",
      "sourceMaps": true,
      "resolveSourceMapLocations": ["**", "!**/node_modules/**"],
      "skipFiles": ["<node_internals>/**"],
      "restart": true,
      "timeout": 30000
    },
    // -------------------------------------------------------------------------
    // Backend en host — lanza el servidor dev directamente desde VS Code.
    // Requisito: cd backend && npm install
    // Lee variables desde backend/.dev.vars automáticamente (via tsx --env-file)
    // -------------------------------------------------------------------------
    {
      "name": "Backend: Launch (Host)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "--env-file=.dev.vars", "--inspect=0.0.0.0:9229", "src/server.dev.ts"],
      "cwd": "${workspaceFolder}/backend",
      "localRoot": "${workspaceFolder}/backend",
      "remoteRoot": "${workspaceFolder}/backend",
      "sourceMaps": true,
      "resolveSourceMapLocations": ["**", "!**/node_modules/**"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "restart": false
    },
    // -------------------------------------------------------------------------
    // Frontend: Chrome — lanza el navegador apuntando al Vite dev server
    // Requisito: npm run dev en /frontend
    // -------------------------------------------------------------------------
    {
      "name": "Frontend: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*"
      }
    }
  ],
  // ---------------------------------------------------------------------------
  // Compound: depura backend (Docker) + frontend Chrome en una sola sesión
  // ---------------------------------------------------------------------------
  "compounds": [
    {
      "name": "Full Stack (Docker)",
      "configurations": ["Backend: Attach (Docker)", "Frontend: Chrome"],
      "stopAll": true
    },
    {
      "name": "Full Stack (Host)",
      "configurations": ["Backend: Launch (Host)", "Frontend: Chrome"],
      "stopAll": true
    }
  ]
}
