{
  "name": "knowto-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --require ./src/register-md.cjs --env-file=.dev.vars -r tsx/cjs src/server.dev.ts",
    "dev:debug": "node --require ./src/register-md.cjs --env-file=.dev.vars --inspect=0.0.0.0:9229 -r tsx/cjs src/server.dev.ts",
    "dev:wrangler": "wrangler dev src/index.ts --port 8787",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:prompts": "vitest run --reporter verbose src/__tests__/prompts"
  },
  "dependencies": {
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-openapi": "^0.16.4",
    "@hono/zod-validator": "^0.2.1",
    "@scalar/hono-api-reference": "^0.5.184",
    "@supabase/supabase-js": "^2.39.0",
    "@tavily/core": "^0.7.2",
    "cheerio": "^1.2.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.1.0",
    "yaml": "^2.8.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240222.0",
    "@hono/node-server": "^1.19.12",
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "wrangler": "^3.28.4"
  }
}
